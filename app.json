{
  "expo": {
    "name": "TPanel",
    "slug": "medidor-angulos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/tpanel_logo_only.png",
    "scheme": "tpanel",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/tpanel_logo_only.png",
        "backgroundImage": "./assets/images/android_icon_background.png",
        "monochromeImage": "./assets/images/android_icon_monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.borrao.tpanel"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/tpanel_logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "363cec31-6216-4801-bcdc-f0476ee5acae"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/363cec31-6216-4801-bcdc-f0476ee5acae",
      "fallbackToCacheTimeout": 0
    },
    "owner": "borrao"
  }
}
